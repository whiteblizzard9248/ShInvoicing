<?xml version="1.0" encoding="UTF-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShInvoicing.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="800"
        x:Class="ShInvoicing.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ShInvoicing">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                Background="#E0E0E0"
                Height="28"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="10,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#333333" />
        </Border>
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="10"
                        Spacing="8">
                <Button Content="Load Excel File"
                        Command="{Binding LoadExcelFileCommand}"
                        Margin="0,0,10,0" />
                <Button Content="Generate PDF"
                        Command="{Binding GeneratePdfCommand}"
                        IsEnabled="{Binding SelectedInvoice, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button Content="Save Vendor"
                        Command="{Binding SaveVendorSettingsCommand}"
                        Margin="10,0,0,0" />
                <Button Content="{Binding VendorDetailsToggleText}"
                        Command="{Binding ToggleVendorDetailsCommand}"
                        Margin="10,0,0,0" />
            </StackPanel>
            <Border Grid.Row="1"
                    Margin="10"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    IsVisible="{Binding IsVendorDetailsVisible}">
                <StackPanel>
                    <TextBlock Text="Vendor Details"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,8" />
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto"
                          RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Grid.Row="0"
                                   Text="Vendor Name:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBox Grid.Column="1"
                                 Grid.Row="0"
                                 Text="{Binding VendorSettings.VendorName, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2"
                                   Grid.Row="0"
                                   Text="GSTIN:"
                                   VerticalAlignment="Center"
                                   Margin="8,0,4,0" />
                        <TextBox Grid.Column="3"
                                 Grid.Row="0"
                                 Text="{Binding VendorSettings.GSTIN, Mode=TwoWay}" />
                        <TextBlock Grid.Column="4"
                                   Grid.Row="0"
                                   Text="PAN:"
                                   VerticalAlignment="Center"
                                   Margin="8,0,4,0" />
                        <TextBox Grid.Column="5"
                                 Grid.Row="0"
                                 Text="{Binding VendorSettings.PANNo, Mode=TwoWay}" />
                        <TextBlock Grid.Column="0"
                                   Grid.Row="1"
                                   Text="Address:"
                                   VerticalAlignment="Center"
                                   Margin="0,4,4,0" />
                        <TextBox Grid.Column="1"
                                 Grid.Row="1"
                                 Text="{Binding VendorSettings.VendorAddress, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2"
                                   Grid.Row="1"
                                   Text="Bank A/C:"
                                   VerticalAlignment="Center"
                                   Margin="8,4,4,0" />
                        <TextBox Grid.Column="3"
                                 Grid.Row="1"
                                 Text="{Binding VendorSettings.BankAccountNo, Mode=TwoWay}" />
                        <TextBlock Grid.Column="4"
                                   Grid.Row="1"
                                   Text="IFSC:"
                                   VerticalAlignment="Center"
                                   Margin="8,4,4,0" />
                        <TextBox Grid.Column="5"
                                 Grid.Row="1"
                                 Text="{Binding VendorSettings.IFSC, Mode=TwoWay}" />
                        <TextBlock Grid.Column="0"
                                   Grid.Row="2"
                                   Text="Mobile:"
                                   VerticalAlignment="Center"
                                   Margin="0,4,4,0" />
                        <TextBox Grid.Column="1"
                                 Grid.Row="2"
                                 Text="{Binding VendorSettings.MobileNumber, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2"
                                   Grid.Row="2"
                                   Text="Email:"
                                   VerticalAlignment="Center"
                                   Margin="8,4,4,0" />
                        <TextBox Grid.Column="3"
                                 Grid.Row="2"
                                 Grid.ColumnSpan="3"
                                 Text="{Binding VendorSettings.Email, Mode=TwoWay}" />
                    </Grid>
                    <Separator Margin="0,8" />
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,*,Auto"
                          RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Grid.Row="0"
                                   Text="Logo Path:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBox Grid.Column="1"
                                 Grid.Row="0"
                                 Text="{Binding VendorSettings.LogoPath, Mode=TwoWay}" />
                        <Button Grid.Column="2"
                                Grid.Row="0"
                                Content="Browse Logo"
                                Command="{Binding BrowseLogoPathCommand}"
                                Margin="8,0,0,0" />
                        <TextBlock Grid.Column="0"
                                   Grid.Row="1"
                                   Text="Download Path:"
                                   VerticalAlignment="Center"
                                   Margin="0,4,4,0" />
                        <TextBox Grid.Column="1"
                                 Grid.Row="1"
                                 Text="{Binding VendorSettings.Address, Mode=TwoWay}" />
                        <Button Grid.Column="2"
                                Grid.Row="1"
                                Content="Select Folder"
                                Command="{Binding BrowseDownloadPathCommand}"
                                Margin="8,4,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
            <Grid Grid.Row="2"
                  ColumnDefinitions="2*,3*"
                  RowDefinitions="*">
                <Border Grid.Column="0"
                        Margin="10"
                        Padding="8"
                        Background="#f4f6fb"
                        BorderBrush="#c5c9d8"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Invoices"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,8">
                            <TextBox Width="200"
                                     Watermark="Search invoice no or customer"
                                     Text="{Binding SearchQuery, Mode=TwoWay}" />
                            <TextBlock Text="{Binding FilteredInvoiceCountSummary}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#333" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding FilteredInvoices}"
                                 SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6"
                                            Margin="0,0,0,4"
                                            Background="#ffffff"
                                            CornerRadius="4"
                                            BorderBrush="#c5c9d8"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding InvoiceNo}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding InvoiceDate, StringFormat='Date: {0:dd-MM-yyyy}'}"
                                                       FontSize="11"
                                                       Foreground="#666" />
                                            <TextBlock Text="{Binding CustomerName}"
                                                       FontSize="11"
                                                       Foreground="#444"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding GrandTotal, StringFormat='Total: {0:C}'}"
                                                       FontSize="11"
                                                       Foreground="#222" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    Spacing="6">
                            <Button Content="Previous"
                                    Command="{Binding PreviousPageCommand}"
                                    IsEnabled="{Binding IsPreviousPageEnabled}" />
                            <TextBlock Text="{Binding PageInfo}"
                                       VerticalAlignment="Center" />
                            <Button Content="Next"
                                    Command="{Binding NextPageCommand}"
                                    IsEnabled="{Binding IsNextPageEnabled}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1"
                        Margin="10"
                        Padding="8"
                        Background="#ffffff"
                        BorderBrush="#c5c9d8"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid RowDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Grid.Row="0"
                                   Text="{Binding InvoiceItemsHeader}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8" />
                        <DataGrid Grid.Row="1"
                                  Height="300"
                                  ItemsSource="{Binding FilteredInvoiceItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description"
                                                    Binding="{Binding Description}" />
                                <DataGridTextColumn Header="HSN/SAC"
                                                    Binding="{Binding HSNSACCode}" />
                                <DataGridTextColumn Header="Units"
                                                    Binding="{Binding Units}" />
                                <DataGridTextColumn Header="Quantity"
                                                    Binding="{Binding Quantity}" />
                                <DataGridTextColumn Header="Rate"
                                                    Binding="{Binding Rate}" />
                                <DataGridTextColumn Header="Taxable Value"
                                                    Binding="{Binding TaxableValue}" />
                                <DataGridTextColumn Header="CGST"
                                                    Binding="{Binding CGSTAmount}" />
                                <DataGridTextColumn Header="SGST"
                                                    Binding="{Binding SGSTAmount}" />
                                <DataGridTextColumn Header="IGST"
                                                    Binding="{Binding IGSTAmount}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="2"
                                   Text="No items found"
                                   FontStyle="Italic"
                                   Foreground="#b22222"
                                   Margin="4,8,0,0"
                                   IsVisible="{Binding IsInvoiceItemsEmpty}" />
                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    Spacing="6">
                            <Button Content="Previous"
                                    Command="{Binding PreviousInvoiceItemsPageCommand}"
                                    IsEnabled="{Binding IsInvoiceItemsPreviousEnabled}" />
                            <TextBlock Text="{Binding InvoiceItemsPageInfo}"
                                       VerticalAlignment="Center" />
                            <Button Content="Next"
                                    Command="{Binding NextInvoiceItemsPageCommand}"
                                    IsEnabled="{Binding IsInvoiceItemsNextEnabled}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>