<?xml version="1.0" encoding="UTF-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShInvoicing.ViewModels"
        xmlns:models="clr-namespace:ShInvoicing.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ShInvoicing.Views.MainWindow"
        x:CompileBindings="False"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ShInvoicing Pharmacy POS">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <DockPanel>
        <!-- Top Navigation Header -->
        <Border DockPanel.Dock="Top"
                Background="#1F2937"
                Padding="16">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  VerticalAlignment="Center">
                <TextBlock Text="ShInvoicing Pharmacy"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">
                    <Button Content="Dashboard"
                            Command="{Binding ShowDashboardCommand}"
                            IsVisible="{Binding IsAuthenticated}" />
                    <Button Content="Inventory"
                            Command="{Binding ShowInventoryCommand}"
                            IsVisible="{Binding CanUseInventory}" />
                    <Button Content="Sales"
                            Command="{Binding ShowSalesCommand}"
                            IsVisible="{Binding CanUseSales}" />
                    <Button Content="Purchase"
                            Command="{Binding ShowPurchaseCommand}"
                            IsVisible="{Binding CanUsePurchases}" />
                    <Button Content="Invoices"
                            Command="{Binding ShowInvoicesCommand}"
                            IsVisible="{Binding IsAuthenticated}" />
                    <Button Content="Users"
                            Command="{Binding ShowUsersCommand}"
                            IsVisible="{Binding CanManageUsers}" />
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12">
                    <TextBlock Text="{Binding CurrentUser.DisplayName}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               IsVisible="{Binding IsAuthenticated}" />
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            IsVisible="{Binding IsAuthenticated}" />
                </StackPanel>
            </Grid>
        </Border>
        <!-- Main Content -->
        <ScrollViewer>
            <StackPanel Margin="20"
                        Spacing="20">
                <!-- Login -->
                <Border Background="#F8FAFC"
                        Padding="24"
                        CornerRadius="8"
                        IsVisible="{Binding IsLoginVisible}">
                    <StackPanel Spacing="16"
                                MaxWidth="400">
                        <TextBlock Text="Login to ShInvoicing"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Default: admin / admin123"
                                   FontSize="12"
                                   Foreground="#666" />
                        <TextBox Watermark="Username"
                                 Text="{Binding LoginUsername, Mode=TwoWay}" />
                        <TextBox Watermark="Password"
                                 PasswordChar="*"
                                 Text="{Binding LoginPassword, Mode=TwoWay}" />
                        <Button Content="Login"
                                Command="{Binding LoginCommand}"
                                Classes="primary" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                    </StackPanel>
                </Border>
                <!-- Dashboard -->
                <Border Background="#FFFFFF"
                        Padding="24"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        IsVisible="{Binding IsDashboardVisible}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Dashboard"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="1*,1*,1*"
                              ColumnSpacing="16">
                            <Border Background="#EFF6FF"
                                    Padding="16"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Total Invoices"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Invoices.Count}"
                                               FontSize="28"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FEF3C7"
                                    Padding="16"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Products"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Products.Count}"
                                               FontSize="28"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#E0E7FF"
                                    Padding="16"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Users"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Users.Count}"
                                               FontSize="28"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Inventory -->
                <Border Background="#FFFFFF"
                        Padding="24"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        IsVisible="{Binding IsInventoryVisible}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Product Inventory"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="1*,1*,1*,Auto"
                              ColumnSpacing="12">
                            <TextBox Text="{Binding NewProductCode, Mode=TwoWay}"
                                     Watermark="Code" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewProductName, Mode=TwoWay}"
                                     Watermark="Name" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding NewProductSaleRate, Mode=TwoWay}"
                                     Watermark="Price" />
                            <Button Grid.Column="3"
                                    Content="Save"
                                    Command="{Binding SaveProductCommand}" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding Products}"
                                  AutoGenerateColumns="False"
                                  Height="300"
                                  IsReadOnly="True"
                                  x:DataType="models:Product">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code"
                                                    Binding="{Binding Code}"
                                                    Width="100" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="200" />
                                <DataGridTextColumn Header="Stock"
                                                    Binding="{Binding StockQty}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Rate"
                                                    Binding="{Binding SaleRate}"
                                                    Width="100" />
                                <DataGridTextColumn Header="GST"
                                                    Binding="{Binding GSTPercent}"
                                                    Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                <!-- Sales -->
                <Border Background="#FFFFFF"
                        Padding="24"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        IsVisible="{Binding IsSalesVisible}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Sales POS"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="1*,1*,Auto,Auto"
                              ColumnSpacing="12">
                            <TextBox Watermark="Product Code"
                                     Text="{Binding SaleProductCode, Mode=TwoWay}" />
                            <TextBox Watermark="Qty"
                                     Text="{Binding SaleQuantity, Mode=TwoWay}" />
                            <Button Content="Add"
                                    Command="{Binding AddSaleItemCommand}" />
                            <Button Content="Complete"
                                    Command="{Binding CreateSalesInvoiceCommand}"
                                    Classes="primary" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding SaleItems}"
                                  AutoGenerateColumns="False"
                                  Height="280"
                                  IsReadOnly="True"
                                  x:DataType="models:InvoiceItem">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code"
                                                    Binding="{Binding ProductCode}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding ProductName}"
                                                    Width="150" />
                                <DataGridTextColumn Header="Qty"
                                                    Binding="{Binding Quantity}"
                                                    Width="60" />
                                <DataGridTextColumn Header="Rate"
                                                    Binding="{Binding Rate}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Total"
                                                    Binding="{Binding LineTotal}"
                                                    Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                <!-- Purchase -->
                <Border Background="#FFFFFF"
                        Padding="24"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        IsVisible="{Binding IsPurchaseVisible}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Purchase Invoice"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="1*,1*,Auto,Auto"
                              ColumnSpacing="12">
                            <TextBox Watermark="Product Code"
                                     Text="{Binding PurchaseProductCode, Mode=TwoWay}" />
                            <TextBox Watermark="Qty"
                                     Text="{Binding PurchaseQuantity, Mode=TwoWay}" />
                            <Button Content="Add"
                                    Command="{Binding AddPurchaseItemCommand}" />
                            <Button Content="Complete"
                                    Command="{Binding CreatePurchaseInvoiceCommand}"
                                    Classes="primary" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding PurchaseItems}"
                                  AutoGenerateColumns="False"
                                  Height="280"
                                  IsReadOnly="True"
                                  x:DataType="models:InvoiceItem">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code"
                                                    Binding="{Binding ProductCode}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding ProductName}"
                                                    Width="150" />
                                <DataGridTextColumn Header="Qty"
                                                    Binding="{Binding Quantity}"
                                                    Width="60" />
                                <DataGridTextColumn Header="Rate"
                                                    Binding="{Binding Rate}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Total"
                                                    Binding="{Binding LineTotal}"
                                                    Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                <!-- Users -->
                <Border Background="#FFFFFF"
                        Padding="24"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        IsVisible="{Binding IsUserManagementVisible}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="User Management"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="1*,1*,1*,Auto"
                              ColumnSpacing="12">
                            <TextBox Watermark="Username"
                                     Text="{Binding NewUserUsername, Mode=TwoWay}" />
                            <TextBox Watermark="Name"
                                     Text="{Binding NewUserDisplayName, Mode=TwoWay}" />
                            <TextBox Watermark="Password"
                                     PasswordChar="*"
                                     Text="{Binding NewUserPassword, Mode=TwoWay}" />
                            <Button Content="Create"
                                    Command="{Binding CreateUserCommand}" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding Users}"
                                  AutoGenerateColumns="False"
                                  Height="300"
                                  IsReadOnly="True"
                                  x:DataType="models:ApplicationUser">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Username"
                                                    Binding="{Binding Username}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding DisplayName}"
                                                    Width="150" />
                                <DataGridTextColumn Header="Role"
                                                    Binding="{Binding RoleName}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                <!-- Invoices -->
                <Border Background="#FFFFFF"
                        Padding="24"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        IsVisible="{Binding IsInvoiceListVisible}">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Text="Invoice History"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBox Grid.Row="1"
                                 Watermark="Search..."
                                 Text="{Binding SearchQuery, Mode=TwoWay}"
                                 Margin="0,12,0,0" />
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  Height="350"
                                  Margin="0,12,0,0"
                                  IsReadOnly="True"
                                  x:DataType="models:Invoice">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No"
                                                    Binding="{Binding InvoiceNo}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Type"
                                                    Binding="{Binding InvoiceType}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Date"
                                                    Binding="{Binding InvoiceDate, StringFormat='dd-MM-yyyy'}"
                                                    Width="100" />
                                <DataGridTextColumn Header="Party"
                                                    Binding="{Binding CounterpartyName}"
                                                    Width="150" />
                                <DataGridTextColumn Header="Total"
                                                    Binding="{Binding GrandTotal}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8"
                                    Margin="0,12,0,0">
                            <Button Content="Previous"
                                    Command="{Binding PreviousPageCommand}"
                                    IsEnabled="{Binding IsPreviousPageEnabled}" />
                            <TextBlock Text="{Binding PageInfo}"
                                       VerticalAlignment="Center" />
                            <Button Content="Next"
                                    Command="{Binding NextPageCommand}"
                                    IsEnabled="{Binding IsNextPageEnabled}" />
                            <Button Content="PDF"
                                    Command="{Binding GeneratePdfCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#E5E7EB"
                Height="32"
                Padding="12">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#0F172A"
                       VerticalAlignment="Center"
                       FontSize="12" />
        </Border>
    </DockPanel>
</Window>