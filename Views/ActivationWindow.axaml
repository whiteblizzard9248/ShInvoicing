<?xml version="1.0" encoding="UTF-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShInvoicing.ViewModels"
        x:Class="ShInvoicing.Views.ActivationWindow"
        x:DataType="vm:ActivationViewModel"
        Width="520"
        Height="420"
        Title="Activate License"
        WindowStartupLocation="CenterScreen">
    <Border Padding="24">
        <StackPanel Spacing="16">
            <!-- Title -->
            <TextBlock Text="License Activation Required"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Text="Please send the Machine ID to the vendor and import the license file."
                       TextWrapping="Wrap"
                       Opacity="0.7" />
            <!-- Machine ID -->
            <StackPanel Spacing="6">
                <TextBlock Text="Machine ID"
                           FontWeight="SemiBold" />
                <TextBox Text="{Binding MachineId}"
                         IsReadOnly="True"
                         HorizontalAlignment="Stretch" />
                <Button Content="Copy Machine ID"
                        HorizontalAlignment="Left"
                        Click="OnCopyMachineId" />
            </StackPanel>
            <!-- Import License -->
            <StackPanel Spacing="6">
                <TextBlock Text="License File"
                           FontWeight="SemiBold" />
                <Button Content="Import License (.json)"
                        HorizontalAlignment="Left"
                        Click="OnImportLicense" />
            </StackPanel>
            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="Green"
                       TextWrapping="Wrap" />
            <!-- Exit -->
            <Button Content="Exit"
                    HorizontalAlignment="Right"
                    Click="OnExit" />
        </StackPanel>
    </Border>
</Window>